{
  "name": "metdb",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "dev:db:start": "docker compose -p metdb_dev -f docker-compose.dev.yml up -d db",
    "dev:db:stop": "docker compose -p metdb_dev -f docker-compose.dev.yml down",
    "dev:db:push": "docker run --rm --network metdb_dev_default -v $(pwd):/app -w /app node:20-alpine sh -c 'DATABASE_URL=\"postgresql://postgres:postgres@db:5432/metdb?schema=public\" npx prisma db push'",
    "dev:reset": "npm run dev:db:stop && docker volume rm metdb_dev_postgres_dev_data || true && npm run dev:db:start && sleep 3 && npm run dev:db:push",
    "prod:local:start": "docker compose -p metdb_prod -f docker-compose.prod.yml up -d --build",
    "prod:local:stop": "docker compose -p metdb_prod -f docker-compose.prod.yml down -v"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/genai": "^1.46.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "google-auth-library": "^10.6.2",
    "googleapis": "^171.4.0",
    "next": "16.2.1",
    "next-auth": "^4.24.13",
    "node-addon-api": "^8.7.0",
    "node-gyp": "^12.2.0",
    "openseadragon": "^6.0.2",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/openseadragon": "^5.0.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "prisma": "^7.5.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
